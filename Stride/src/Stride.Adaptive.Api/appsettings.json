{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/adaptive-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName"]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=stride;Username=postgres;Password=postgres"
  },
  "DifficultyEngine": {
    "ModelFilePath": "MLModels/difficulty_model.zip",
    "MinDifficulty": 1,
    "MaxDifficulty": 100,
    "TargetAccuracyLow": 0.70,
    "TargetAccuracyHigh": 0.80,
    "DefaultDifficulty": 50,
    "ConfidenceThreshold": 0.6
  },
  "ModelTraining": {
    "SyntheticSampleCount": 10000,
    "MinRealDataPoints": 500,
    "RetrainingIntervalHours": 168,
    "NumberOfLeaves": 20,
    "NumberOfTrees": 100,
    "LearningRate": 0.05,
    "MinDataPointsInLeaves": 10
  },
  "TaskPool": {
    "TargetPoolSize": 50,
    "RefillThreshold": 20,
    "DifficultyRangeWindow": 10,
    "PoolTtlHours": 24,
    "MaxCachedTasks": 100,
    "CacheDuration": "00:30:00"
  },
  "AIProvider": {
    "DefaultProvider": "anthropic",
    "MaxRetries": 3,
    "RetryDelayMs": 1000,
    "TimeoutSeconds": 600,
    "BatchDelayMs": 4000,
    "Anthropic": {
      "ApiKey": "your-anthropic-api-key-here",
      "Model": "claude-haiku-4-5-20251001",
      "ApiUrl": "https://api.anthropic.com/v1/messages",
      "Temperature": 0.7,
      "MaxOutputTokens": 8192
    },
    "Gemini": {
      "ApiKey": "your-gemini-api-key-here",
      "Model": "gemini-3-flash-preview",
      "ApiUrl": "https://generativelanguage.googleapis.com/v1beta/models",
      "Temperature": 0.7,
      "MaxOutputTokens": 8192
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "stride"
  },
  "Valkey": {
    "ConnectionString": "localhost:6379",
    "DefaultExpirationMinutes": 60,
    "InstanceName": "Stride:"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSSL": false,
    "Region": "us-east-1",
    "Buckets": {
      "Avatars": "avatars",
      "Assets": "assets"
    }
  },
  "Meilisearch": {
    "Url": "http://localhost:7700",
    "MasterKey": "masterKey",
    "Indexes": {
      "Subjects": "subjects",
      "Topics": "topics"
    }
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-min-32-chars-for-production-use-only-change-this-in-production",
    "Issuer": "Stride",
    "Audience": "Stride.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  }
}
