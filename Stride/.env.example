# Stride Environment Variables
# Copy this file to .env and update with your values

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# Database - PostgreSQL
ConnectionStrings__PostgreSQL=Host=postgres;Port=5432;Database=stride;Username=postgres;Password=postgres

# Database - MongoDB
ConnectionStrings__MongoDB=mongodb://mongodb:27017
MongoDB__ConnectionString=mongodb://mongodb:27017
MongoDB__DatabaseName=stride

# Cache - Valkey (Redis)
Valkey__ConnectionString=valkey:6379
Valkey__DefaultExpirationMinutes=60
Valkey__InstanceName=Stride:

# Storage - MinIO
MinIO__Endpoint=minio:9000
MinIO__AccessKey=minioadmin
MinIO__SecretKey=minioadmin
MinIO__UseSSL=false
MinIO__Region=us-east-1
MinIO__Buckets__Avatars=avatars
MinIO__Buckets__Assets=assets

# Search - Meilisearch
Meilisearch__Url=http://meilisearch:7700
Meilisearch__MasterKey=masterKey
Meilisearch__Indexes__Subjects=subjects
Meilisearch__Indexes__Topics=topics

# Logging
Serilog__MinimumLevel__Default=Information

# CORS (comma-separated origins for production)
# CorsOrigins=https://stride.app,https://www.stride.app
