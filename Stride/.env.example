# Stride Environment Variables
# Copy this file to .env and update with your values

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# Database - PostgreSQL
ConnectionStrings__PostgreSQL=Host=postgres;Port=5432;Database=stride;Username=postgres;Password=postgres

# Database - MongoDB
ConnectionStrings__MongoDB=mongodb://mongodb:27017
MongoDB__ConnectionString=mongodb://mongodb:27017
MongoDB__DatabaseName=stride

# Cache - Valkey (Redis)
Valkey__ConnectionString=valkey:6379
Valkey__DefaultExpirationMinutes=60
Valkey__InstanceName=Stride:

# Storage - MinIO
MinIO__Endpoint=minio:9000
MinIO__AccessKey=minioadmin
MinIO__SecretKey=minioadmin
MinIO__UseSSL=false
MinIO__Region=us-east-1
MinIO__Buckets__Avatars=avatars
MinIO__Buckets__Assets=assets

# Search - Meilisearch
Meilisearch__Url=http://meilisearch:7700
Meilisearch__MasterKey=masterKey
Meilisearch__Indexes__Subjects=subjects
Meilisearch__Indexes__Topics=topics

# Logging
Serilog__MinimumLevel__Default=Information

# AI Provider (used by both Stride.Api and Stride.Adaptive.Api)
# Active provider — "anthropic" (current) or "gemini" (legacy fallback)
AIProvider__DefaultProvider=anthropic

# Anthropic (primary)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AIProvider__Anthropic__ApiKey=${ANTHROPIC_API_KEY}
AIProvider__Anthropic__Model=claude-haiku-4-5-20251001

# Gemini (legacy / fallback — only read when DefaultProvider=gemini)
AIProvider__Gemini__ApiKey=your-gemini-api-key-here
AIProvider__Gemini__Model=gemini-3-flash-preview

# JWT signing (DO NOT commit the real value — set in the deployed .env)
JwtSettings__Secret=your-super-secret-key-min-32-chars-for-production-use-only-change-this-in-production
JwtSettings__Issuer=stride-api
JwtSettings__Audience=stride-clients
JwtSettings__AccessTokenMinutes=15
JwtSettings__RefreshTokenDays=14

# CORS (comma-separated origins for production)
# CORS_ALLOWED_ORIGINS=https://stride.app,https://www.stride.app

# Adaptive ML
DifficultyEngine__ModelFilePath=MLModels/difficulty_model.zip
ModelTraining__RetrainingIntervalHours=168
