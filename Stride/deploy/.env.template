# Copy this to /opt/stride/.env on the server and fill in real values.

# --- AI provider ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=

# --- JWT ---
JWT_SECRET=change-me-min-32-chars-random-secret

# --- PostgreSQL ---
POSTGRES_USER=stride
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stride

# --- MongoDB ---
MONGO_USER=stride
MONGO_PASSWORD=change-me

# --- Valkey / Redis ---
VALKEY_PASSWORD=change-me

# --- MinIO (object storage for avatars) ---
MINIO_USER=stride
MINIO_PASSWORD=change-me

# --- Meilisearch ---
MEILI_MASTER_KEY=change-me-random-key

# --- CORS: add your LXC IP ---
CORS_ALLOWED_ORIGINS=https://192.168.31.30,http://192.168.31.30

# --- Optional ---
ASPNETCORE_ENVIRONMENT=Production
